# ============================================================
# FindIt — Environment Variables (Example)
# Copy this file to .env and fill in your actual API keys
# ============================================================

# ── Phase 1: Google Maps Search ──────────────────────────────
SERPAPI_KEY=your_serpapi_key_here

# ── Phase 2: Web Discovery (Jina AI) ─────────────────────────
JINA_API_KEY=your_jina_api_key_here

# ── Phase 2: Website Crawling (Firecrawl) ────────────────────
FIRECRAWL_API_KEY=your_firecrawl_api_key_here

# ── Phase 2: Email Discovery (Hunter.io) ─────────────────────
HUNTER_API_KEY=your_hunter_api_key_here

# ── Phase 2: LinkedIn via Piloterr ───────────────────────────
PILOTERR_API_KEY=your_piloterr_api_key_here

# ── Supabase Database ─────────────────────────────────────────
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_KEY=your_anon_key_here

# ── Google OAuth Credentials ──────────────────────────────────
GOOGLE_CLIENT_ID=your_google_client_id_here.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your_google_client_secret_here
# Optional: REDIRECT_URI (defaults to http://localhost:8000/auth/callback/google)
# GOOGLE_REDIRECT_URI=http://localhost:8000/auth/callback/google

